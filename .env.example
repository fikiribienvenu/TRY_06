# MongoDB
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=pulmoscan_secret
MONGODB_URL=mongodb://admin:pulmoscan_secret@localhost:27017/pulmoscan?authSource=admin

# JWT
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET_KEY=your-super-secret-refresh-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@pulmoscan.ai
EMAIL_FROM_NAME=PulmoScan AI

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# App
APP_NAME=PulmoScan AI
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ENVIRONMENT=development
DEBUG=true

# File Upload
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,dcm

# Director Default Password
DIRECTOR_EMAIL=director@pulmoscan.ai
DIRECTOR_DEFAULT_PASSWORD=Director@2024!
