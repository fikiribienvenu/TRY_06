MONGODB_URL=mongodb://admin:pulmoscan_secret@localhost:27017/pulmoscan?authSource=admin
DB_NAME=pulmoscan

JWT_SECRET_KEY=change-this-to-a-very-long-random-secret-key
JWT_REFRESH_SECRET_KEY=change-this-to-another-very-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@pulmoscan.ai
EMAIL_FROM_NAME=PulmoScan AI

GEMINI_API_KEY=your-gemini-api-key

APP_NAME=PulmoScan AI
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
DEBUG=true

MAX_FILE_SIZE_MB=50
UPLOAD_DIR=uploads

DIRECTOR_EMAIL=director@pulmoscan.ai
DIRECTOR_DEFAULT_PASSWORD=Director@2024!
DIRECTOR_FIRST_NAME=System
DIRECTOR_LAST_NAME=Director
